---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo-lockup">
			<svg width="46" height="32" viewBox="0 0 52 36" aria-hidden="true">
				<defs><path id="ha" d="M 5 28 Q 26 3 47 28"/></defs>
				<path d="M 5 28 Q 26 3 47 28" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
				<circle cx="5" cy="28" r="3.5" fill="currentColor"/>
				<circle cx="47" cy="28" r="3.5" fill="currentColor"/>
				<circle r="3" fill="var(--accent)">
					<animateMotion dur="2.2s" repeatCount="indefinite">
						<mpath href="#ha"/>
					</animateMotion>
				</circle>
			</svg>
			<div class="wordmark"><span class="pay">pay</span><span class="arch">arch</span></div>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://m.webtoo.ls/@astro" target="_blank">
				<span class="sr-only">Follow Astro on Mastodon</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"
					></path></svg
				>
			</a>
			<a href="https://twitter.com/astrodotbuild" target="_blank">
				<span class="sr-only">Follow Astro on Twitter</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
			<a href="https://github.com/withastro/astro" target="_blank">
				<span class="sr-only">Go to Astro's GitHub repo</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-color);
		position: sticky;
		top: 0;
		z-index: 50;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 860px;
		margin: 0 auto;
		padding: 0 max(1em, env(safe-area-inset-right)) 0 max(1em, env(safe-area-inset-left));
		height: 70px;
		gap: 0.5rem;
		min-width: 0;
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	h2 a {
		text-decoration: none;
		color: rgb(var(--black));
	}
	.internal-links {
		display: flex;
		gap: 0.5em;
		flex-shrink: 0;
	}
	nav a.link-item {
		padding: 0.5em 0.8em;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.95em;
		font-weight: 500;
		border-radius: 6px;
		transition: all 0.2s ease;
	}
	nav a.link-item:hover {
		background: var(--bg-subtle);
		color: rgb(var(--black));
	}
	nav a.active {
		color: var(--accent);
		background: var(--accent-light);
	}
	.social-links {
		display: flex;
		gap: 0.5em;
	}
	.social-links a {
		color: rgb(var(--gray));
		transition: color 0.2s;
		display: flex;
		align-items: center;
		padding: 0.5em;
	}
	.social-links a:hover {
		color: rgb(var(--black));
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
	
	@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;500&display=swap');
	
	.logo-lockup {
		display: flex;
		align-items: center;
		gap: 6px;
		text-decoration: none !important;
		color: rgb(var(--black));
		transition: opacity 0.2s ease;
		min-width: 0;
	}
	.logo-lockup:hover {
		opacity: 0.8;
	}
	.wordmark {
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		letter-spacing: -0.03em;
		display: flex;
		align-items: center;
		transform: translateY(1px); /* optical alignment with arch */
	}
	.wordmark .pay { font-weight: 300; }
	.wordmark .arch { font-weight: 500; }
	@media (max-width: 480px) {
		nav {
			height: 60px;
			padding-left: max(0.75rem, env(safe-area-inset-left));
			padding-right: max(0.75rem, env(safe-area-inset-right));
		}
		.wordmark {
			font-size: 1.15rem;
		}
		.logo-lockup svg {
			width: 38px;
			height: 26px;
		}
		nav a.link-item {
			padding: 0.45em 0.55em;
			font-size: 0.88em;
		}
	}
</style>
