---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo-lockup">
			<svg width="46" height="32" viewBox="0 0 52 36" aria-hidden="true">
				<defs><path id="ha" d="M 5 28 Q 26 3 47 28"/></defs>
				<path d="M 5 28 Q 26 3 47 28" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
				<circle cx="5" cy="28" r="3.5" fill="currentColor"/>
				<circle cx="47" cy="28" r="3.5" fill="currentColor"/>
				<circle r="3" fill="var(--accent)">
					<animateMotion dur="2.2s" repeatCount="indefinite">
						<mpath href="#ha"/>
					</animateMotion>
				</circle>
			</svg>
			<div class="wordmark"><span class="pay">pay</span><span class="arch">arch</span></div>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-color);
		position: sticky;
		top: 0;
		z-index: 50;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 860px;
		margin: 0 auto;
		padding: 0 max(1em, env(safe-area-inset-right)) 0 max(1em, env(safe-area-inset-left));
		height: 70px;
		gap: 0.5rem;
		min-width: 0;
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	h2 a {
		text-decoration: none;
		color: rgb(var(--black));
	}
	.internal-links {
		display: flex;
		gap: 0.5em;
		flex-shrink: 0;
	}
	nav a.link-item {
		padding: 0.5em 0.8em;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.95em;
		font-weight: 500;
		border-radius: 6px;
		transition: all 0.2s ease;
	}
	nav a.link-item:hover {
		background: var(--bg-subtle);
		color: rgb(var(--black));
	}
	nav a.active {
		color: var(--accent);
		background: var(--accent-light);
	}

	@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;500&display=swap');
	
	.logo-lockup {
		display: flex;
		align-items: center;
		gap: 6px;
		text-decoration: none !important;
		color: rgb(var(--black));
		transition: opacity 0.2s ease;
		min-width: 0;
	}
	.logo-lockup:hover {
		opacity: 0.8;
	}
	.wordmark {
		font-family: 'Outfit', sans-serif;
		font-size: 24px;
		letter-spacing: -0.03em;
		display: flex;
		align-items: center;
		transform: translateY(1px); /* optical alignment with arch */
	}
	.wordmark .pay { font-weight: 300; }
	.wordmark .arch { font-weight: 500; }
	@media (max-width: 480px) {
		nav {
			height: 60px;
			padding-left: max(0.75rem, env(safe-area-inset-left));
			padding-right: max(0.75rem, env(safe-area-inset-right));
		}
		.wordmark {
			font-size: 1.15rem;
		}
		.logo-lockup svg {
			width: 38px;
			height: 26px;
		}
		nav a.link-item {
			padding: 0.45em 0.55em;
			font-size: 0.88em;
		}
	}
</style>
