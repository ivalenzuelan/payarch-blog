---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props as Props & { tags?: string[] };
---

<html lang="en">
<head>
  <BaseHead title={title} description={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet" />

  <style is:global>
    /* ── Landing design tokens ─────────────────────────────── */
    :root {
      --cream:  #faf9f6;
      --cream2: #f5f3ee;
      --cream3: #ede9e2;
      --ink:    #1a1814;
      --ink2:   #4a4840;
      --ink3:   #8a8278;
      --ink4:   #b8b3a8;
      --ink5:   #d8d3c8;
      --orange: #c05020;
      --orange2:#e07040;
      --border: #e0dbd0;

      /* remap global.css variables so existing components stay consistent */
      --accent:       #c05020;
      --accent-dark:  #a03010;
      --accent-light: #fff6f2;
      --bg-body:      #faf9f6;
      --bg-subtle:    #f5f3ee;
      --border-color: #e0dbd0;
      --box-shadow:   0 2px 8px rgba(26,24,20,0.06), 0 8px 24px rgba(26,24,20,0.04);
      --black: 26,24,20;
      --gray:  138,130,120;
      --gray-light: 237,233,226;
      --gray-dark:  74,72,64;
    }

    /* ── Base ──────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box }

    body {
      background: var(--cream) !important;
      color: var(--ink) !important;
      font-family: 'Outfit', system-ui, sans-serif !important;
      font-weight: 400;
      font-size: 18px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Typography ────────────────────────────────────────── */
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Instrument Serif', Georgia, serif !important;
      font-weight: 400 !important;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--ink) !important;
    }
    h1 { font-size: clamp(2rem, 5vw, 3rem); }
    h2 { font-size: clamp(1.5rem, 3.5vw, 2rem);  margin-top: 2.5em; margin-bottom: 0.5em; }
    h3 { font-size: clamp(1.2rem, 2.5vw, 1.5rem); margin-top: 2em;   margin-bottom: 0.4em; }

    p {
      color: var(--ink2);
      margin-bottom: 1.6em;
      font-weight: 300;
      font-size: 1.02rem;
      line-height: 1.8;
    }

    a { color: var(--orange); text-decoration: none; transition: color .15s; }
    a:hover { color: var(--orange2); }

    strong, b { font-weight: 500; color: var(--ink); }

    /* ── Code ──────────────────────────────────────────────── */
    code {
      font-family: 'DM Mono', ui-monospace, monospace !important;
      font-size: 0.82em;
      background: var(--cream3) !important;
      border: 1px solid var(--border) !important;
      border-radius: 4px;
      padding: 0.15em 0.45em;
      color: var(--ink2) !important;
    }
    pre code {
      background: transparent !important;
      border: none !important;
      padding: 0;
      font-size: inherit;
      color: inherit !important;
    }
    pre {
      font-family: 'DM Mono', ui-monospace, monospace !important;
      font-size: 0.84em;
      line-height: 1.65;
      border-radius: 10px;
      border: 1px solid var(--border);
      overflow-x: auto;
      padding: 1.4em 1.6em;
    }
    pre:not(.astro-code) {
      background: var(--cream2) !important;
      color: var(--ink) !important;
    }
    pre:not(.astro-code) > code {
      all: unset;
      display: block;
      font-family: 'DM Mono', ui-monospace, monospace !important;
      color: var(--ink) !important;
    }
    pre.astro-code { border-color: #3d444d; }
    pre.astro-code code { display: block; width: 100%; background: transparent !important; border: none !important; }

    /* ── Blockquote ────────────────────────────────────────── */
    blockquote {
      border-left: 3px solid var(--orange);
      padding: 0.5em 0 0.5em 1.5em;
      margin: 2em 0;
      background: #fff6f2;
      border-radius: 0 6px 6px 0;
      font-style: italic;
      color: var(--ink3);
    }

    /* ── HR ────────────────────────────────────────────────── */
    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 3em 0;
    }

    /* ── Tables ────────────────────────────────────────────── */
    table { width: 100%; border-collapse: collapse; font-size: 0.9em; }
    th {
      font-family: 'DM Mono', monospace !important;
      font-size: 0.78em;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background: var(--cream2);
      border-bottom: 1px solid var(--border);
      padding: 0.6em 0.9em;
      text-align: left;
      font-weight: 500;
    }
    td {
      padding: 0.55em 0.9em;
      border-bottom: 1px solid var(--cream3);
      color: var(--ink2);
      vertical-align: top;
    }
    tr:last-child td { border-bottom: none; }

    /* ── Images ────────────────────────────────────────────── */
    img { max-width: 100%; height: auto; border-radius: 10px; }

    /* ── Reading progress ──────────────────────────────────── */
    #reading-progress {
      position: fixed; top: 0; left: 0;
      height: 2px; background: var(--orange);
      z-index: 200; width: 0%;
      transition: width 0.1s linear;
    }

    /* ── Diagram touch targets ──────────────────────────────── */
    .fourparty-flow button { min-height: 36px; }

    /* ── Mobile ────────────────────────────────────────────── */
    @media (max-width: 640px) {
      body { font-size: 16px; }
      h2 { font-size: 1.45rem; }
      h3 { font-size: 1.2rem; }

      /* Diagrams: edge-to-edge + scrollable */
      .not-prose {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        margin-left: -16px !important;
        margin-right: -16px !important;
        padding-left: 16px;
        padding-right: 16px;
      }

      /* Code blocks scrollable */
      pre {
        font-size: 0.76em;
        padding: 1em;
      }

      /* Prose table scrollable */
      table {
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
    }
  </style>

  <style>
    /* ── Nav ───────────────────────────────────────────────── */
    .post-nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px; height: 56px;
      background: rgba(250,249,246,0.9);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      display: flex; align-items: center; gap: 8px;
      text-decoration: none; color: var(--ink);
    }
    .nav-wordmark {
      font-family: 'Outfit', sans-serif;
      font-size: 17px; letter-spacing: -0.03em;
    }
    .nav-wordmark .pay { font-weight: 300; }
    .nav-wordmark .arch { font-weight: 500; }
    .nav-links {
      display: flex; align-items: center; gap: 28px;
      list-style: none; margin: 0; padding: 0;
    }
    .nav-links a {
      font-family: 'DM Mono', monospace;
      font-size: 11px; letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--ink3);
      text-decoration: none; transition: color .15s;
    }
    .nav-links a:hover { color: var(--ink); }
    .nav-links .nav-back {
      color: var(--ink4);
      display: flex; align-items: center; gap: 4px;
    }
    .nav-links .nav-back:hover { color: var(--ink2); }

    /* ── Article title header ──────────────────────────────── */
    .post-header {
      position: relative;
      padding: 80px 40px 64px;
      text-align: center;
      overflow: hidden;
      border-bottom: 1px solid var(--border);
    }
    .post-header::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 48px 48px;
      opacity: 0.3;
      pointer-events: none;
    }
    .post-header::after {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 90% 80% at 50% 50%, transparent 30%, var(--cream) 100%);
      pointer-events: none;
    }
    .post-header-inner {
      position: relative; z-index: 1;
      max-width: 700px; margin: 0 auto;
    }
    .post-eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 10px; letter-spacing: 0.13em;
      text-transform: uppercase; color: var(--ink4);
      margin-bottom: 20px;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      animation: fadeUp .6s ease .1s both;
    }
    .post-eyebrow-dot {
      width: 3px; height: 3px; border-radius: 50%;
      background: var(--ink5); display: inline-block;
    }
    .post-title {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(1.8rem, 4.5vw, 2.8rem);
      font-weight: 400; line-height: 1.15;
      letter-spacing: -0.02em; color: var(--ink);
      margin: 0 0 20px;
      animation: fadeUp .7s ease .25s both;
    }
    .post-desc-text {
      font-family: 'Outfit', sans-serif;
      font-size: 16px; font-weight: 300;
      color: var(--ink3); line-height: 1.65;
      max-width: 560px; margin: 0 auto 28px;
      animation: fadeUp .7s ease .35s both;
    }
    .post-tags {
      display: flex; flex-wrap: wrap;
      justify-content: center; gap: 5px;
      margin-bottom: 0;
      animation: fadeUp .6s ease .45s both;
    }
    .post-chip {
      font-family: 'DM Mono', monospace;
      font-size: 9px; letter-spacing: 0.05em;
      text-transform: uppercase; color: var(--ink4);
      background: var(--cream3); border: 1px solid var(--border);
      border-radius: 3px; padding: 3px 8px;
    }

    /* ── Prose wrapper ─────────────────────────────────────── */
    .prose-wrap {
      max-width: 860px; margin: 0 auto;
      padding: 56px max(1.5rem, env(safe-area-inset-right)) 80px max(1.5rem, env(safe-area-inset-left));
    }

    /* ── Section headings get section-label treatment ──────── */
    .prose-wrap h2 {
      display: flex; align-items: center; gap: 12px;
      padding-top: 0.5em;
    }
    .prose-wrap h2::before {
      content: '';
      display: block; width: 24px; height: 1px;
      background: var(--orange); flex-shrink: 0;
      opacity: 0.6;
    }

    /* ── Footer ────────────────────────────────────────────── */
    .post-footer {
      border-top: 1px solid var(--border);
      padding: 32px 40px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .footer-logo {
      display: flex; align-items: center; gap: 10px;
    }
    .footer-copy {
      font-family: 'DM Mono', monospace;
      font-size: 10px; color: var(--ink5); letter-spacing: 0.05em;
    }
    .footer-links {
      display: flex; gap: 24px; list-style: none; margin: 0; padding: 0;
    }
    .footer-links a {
      font-family: 'DM Mono', monospace;
      font-size: 10px; letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--ink4);
      text-decoration: none; transition: color .15s;
    }
    .footer-links a:hover { color: var(--ink); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 640px) {
      /* Nav: only logo + home on small phones */
      .post-nav { padding: 0 16px; }
      .nav-links li:nth-child(1),
      .nav-links li:nth-child(2),
      .nav-links li:nth-child(3) { display: none; }
      .nav-links { gap: 0; }

      /* Header */
      .post-header { padding: 52px 16px 36px; }
      .post-title { font-size: clamp(1.5rem, 6vw, 2rem); }
      .post-desc-text { font-size: 14px; }

      /* Prose */
      .prose-wrap {
        padding-top: 32px;
        padding-bottom: 48px;
        padding-left: max(16px, env(safe-area-inset-left));
        padding-right: max(16px, env(safe-area-inset-right));
      }

      /* Code blocks */
      pre { padding: 1em 1.2em; font-size: 0.78em; }

      /* Footer */
      .post-footer { flex-direction: column; gap: 16px; padding: 24px 16px; }
    }
  </style>
</head>

<body>
  <div id="reading-progress"></div>

  <!-- NAV -->
  <nav class="post-nav">
    <a href="/" class="nav-logo">
      <svg width="36" height="24" viewBox="0 0 36 24">
        <defs><path id="np2" d="M 3 19 Q 18 2 33 19"/></defs>
        <path d="M 3 19 Q 18 2 33 19" fill="none" stroke="#1a1814" stroke-width="1.8" stroke-linecap="round"/>
        <circle cx="3"  cy="19" r="2.5" fill="#1a1814"/>
        <circle cx="33" cy="19" r="2.5" fill="#1a1814"/>
        <circle r="2" fill="#c05020">
          <animateMotion dur="2.2s" repeatCount="indefinite" calcMode="spline" keySplines="0.37 0 0.63 1" keyTimes="0;1">
            <mpath href="#np2"/>
          </animateMotion>
        </circle>
      </svg>
      <div class="nav-wordmark"><span class="pay">pay</span><span class="arch">arch</span></div>
    </a>
    <ul class="nav-links">
      <li><a href="/#posts">Writing</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="https://github.com/ivalenzuelan" target="_blank">GitHub</a></li>
      <li><a href="/" class="nav-back">← Home</a></li>
    </ul>
  </nav>

  <!-- ARTICLE HEADER -->
  <header class="post-header">
    <div class="post-header-inner">
      <div class="post-eyebrow">
        <FormattedDate date={pubDate} />
        {updatedDate && <><span class="post-eyebrow-dot"></span><span>Updated <FormattedDate date={updatedDate} /></span></>}
        {tags && tags.length > 0 && <span class="post-eyebrow-dot"></span>}
        {tags && tags.slice(0, 3).map(t => t).join(' · ')}
      </div>
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-desc-text">{description}</p>}
      {tags && tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => <span class="post-chip">{tag}</span>)}
        </div>
      )}
    </div>
  </header>

  <!-- PROSE CONTENT -->
  <main>
    <div class="prose-wrap">
      <slot />
    </div>
  </main>

  <!-- FOOTER -->
  <footer class="post-footer">
    <div class="footer-logo">
      <svg width="28" height="20" viewBox="0 0 36 24">
        <path d="M 3 19 Q 18 2 33 19" fill="none" stroke="#b8b3a8" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="3"  cy="19" r="2" fill="#b8b3a8"/>
        <circle cx="33" cy="19" r="2" fill="#b8b3a8"/>
      </svg>
      <span class="footer-copy">© 2026 payarch.dev</span>
    </div>
    <ul class="footer-links">
      <li><a href="/#posts">Writing</a></li>
      <li><a href="https://github.com/ivalenzuelan" target="_blank">GitHub</a></li>
      <li><a href="mailto:vn.inigo@gmail.com">Contact</a></li>
    </ul>
  </footer>

  <script>
    const bar = document.getElementById('reading-progress');
    if (bar) {
      window.addEventListener('scroll', () => {
        const doc = document.documentElement;
        bar.style.width = doc.scrollHeight - doc.clientHeight > 0
          ? (doc.scrollTop / (doc.scrollHeight - doc.clientHeight)) * 100 + '%'
          : '0%';
      });
    }
  </script>
</body>
</html>
