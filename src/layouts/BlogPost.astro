---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props as Props & { tags?: string[] };
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding-left: max(0px, env(safe-area-inset-left));
				padding-right: max(0px, env(safe-area-inset-right));
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				max-width: 100%;
				height: auto;
			}
			.prose {
				width: 860px;
				max-width: 100%;
				margin: auto;
				padding: 1em max(1rem, env(safe-area-inset-left)) 4em max(1rem, env(safe-area-inset-right));
				color: rgb(var(--gray-dark));
				box-sizing: border-box;
			}
			.title {
				margin-bottom: 2em;
				padding: 1.5em 0 1em;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.6em 0;
				font-size: clamp(1.45rem, 5vw + 0.5rem, 2.6em);
				line-height: 1.15;
				letter-spacing: -0.02em;
			}
			.date {
				margin-bottom: 0.6em;
				color: rgb(var(--gray));
				font-size: 0.85em;
				letter-spacing: 0.03em;
				text-transform: uppercase;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.4em;
				margin: 1em 0 0.5em;
			}
			.tag {
				display: inline-block;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				font-size: 0.7em;
				font-weight: 600;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				padding: 0.25em 0.7em;
				border-radius: 999px;
			}
			.description {
				font-size: 1.1em;
				color: rgb(var(--gray));
				line-height: 1.5;
				max-width: 640px;
				margin: 0.5em auto 0;
				text-align: center;
			}
			@media (max-width: 640px) {
				.title {
					padding: 1em 0 0.75em;
					margin-bottom: 1.25em;
				}
				.description {
					font-size: 1rem;
					text-align: left;
				}
				.tags {
					justify-content: flex-start;
				}
				.hero-image img {
					border-radius: 8px;
				}
			}
			.last-updated-on {
				font-style: italic;
			}
			/* Code blocks — slightly wider feel */
			.prose pre {
				font-size: 0.82em;
				line-height: 1.6;
				overflow-x: auto;
			}
			/* Better table styling */
			.prose table {
				font-size: 0.9em;
				border-collapse: collapse;
			}
			.prose table th {
				background: rgb(var(--gray-light));
				padding: 0.5em 0.8em;
				text-align: left;
				font-weight: 700;
				font-size: 0.85em;
				letter-spacing: 0.03em;
				text-transform: uppercase;
			}
			.prose table td {
				padding: 0.5em 0.8em;
				border-bottom: 1px solid rgb(var(--gray-light));
				vertical-align: top;
			}
			.prose table tr:last-child td {
				border-bottom: none;
			}
			/* Smooth section separator */
			.prose hr {
				margin: 3em 0;
				border-top: 1px solid rgb(var(--gray-light));
			}
			/* Reading progress bar */
			#reading-progress {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				background: var(--accent);
				z-index: 100;
				transition: width 0.1s linear;
				width: 0%;
			}
		</style>
	</head>

	<body>
		<div id="reading-progress"></div>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage.src} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{description && <p class="description">{description}</p>}
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => <span class="tag">{tag}</span>)}
							</div>
						)}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			const bar = document.getElementById('reading-progress');
			if (bar) {
				window.addEventListener('scroll', () => {
					const doc = document.documentElement;
					const scrolled = doc.scrollTop;
					const total = doc.scrollHeight - doc.clientHeight;
					bar.style.width = total > 0 ? (scrolled / total) * 100 + '%' : '0%';
				});
			}
		</script>
	</body>
</html>
